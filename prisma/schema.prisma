generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum UserPlan {
  GUEST
  FREE
  PLUS
  VIP
}

enum MediaType {
  MOVIE
  SERIES
  ANIME
  VARIETY
  DOCUMENTARY
  SPECIAL
}

enum MediaStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  HIATUS
  ARCHIVED
}

enum CreditRole {
  DIRECTOR
  ACTOR
  WRITER
  PRODUCER
  CREATOR
  VOICE
}

enum ArtworkKind {
  POSTER
  BACKDROP
  THUMBNAIL
  LOGO
  BANNER
}

enum ResourceKind {
  STREAM
  DOWNLOAD
  SUBTITLE
  TRAILER
}

enum ResourceProvider {
  INTERNAL
  M3U8
  MP4
  QUARK
  BAIDU
  ALIYUN
  MAGNET
  OTHER
}

enum ResourceFormat {
  HLS
  MP4
  MKV
  HTML
  NETDISK
  TEXT
}

enum ResourceStatus {
  ONLINE
  DEGRADED
  OFFLINE
  REPORTED
  PENDING
}

enum BrowseEventType {
  HOME_VIEW
  CATEGORY_VIEW
  SEARCH_VIEW
  DETAIL_VIEW
  PLAYER_VIEW
  RESOURCE_ACTION
}

enum ResourceAction {
  OPEN
  COPY
  QR_SCAN
  REPORT_INVALID
}

enum ListType {
  WATCHLIST
  FAVORITES
  HISTORY
  CURATED
}

enum SearchScope {
  ALL
  MOVIE
  SERIES
  ANIME
}

enum DeviceType {
  WEB
  IOS
  ANDROID
  TV
  DESKTOP
}

enum ProviderType {
  CATALOG_PROVIDER
  PLAYBACK_PROVIDER
  DOWNLOAD_PROVIDER
  SUBTITLE_PROVIDER
  MANUAL_SUBMISSION_PROVIDER
}

enum ProviderCapability {
  CATALOG
  PLAYBACK
  DOWNLOAD
  SUBTITLE
  MANUAL_SUBMISSION
}

enum ProviderPayloadFormat {
  JSON
  XML
  HTML
  TEXT
  OTHER
}

enum ProviderContentTypeHint {
  MOVIE
  SERIES
  ANIME
  VARIETY
  DOCUMENTARY
  SPECIAL
  UNKNOWN
}

enum IngestRunScope {
  PAGE
  DETAIL
}

enum IngestMode {
  BACKFILL
  INCREMENTAL
  MANUAL
}

enum IngestJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  PARTIAL
}

enum IngestRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  PARTIAL
}

enum ProviderItemStatus {
  DISCOVERED
  DETAIL_FETCHED
  STAGED
  ERROR
  WITHDRAWN
}

enum StagingCandidateStatus {
  PENDING
  PARSED
  READY_FOR_NORMALIZATION
  PARSE_FAILED
  SKIPPED
}

enum NormalizedMediaType {
  MOVIE
  SERIES
  ANIME
  VARIETY
  DOCUMENTARY
  SPECIAL
  UNKNOWN
}

enum NormalizedCandidateStatus {
  NORMALIZED
  WARNING
  FAILED
}

enum CandidateAliasSource {
  TITLE
  ORIGINAL_TITLE
  DERIVED
}

enum MatchTargetSource {
  CANONICAL
  NORMALIZED_CANDIDATE
}

enum MatchSuggestionKind {
  EXACT
  PROBABLE
  AMBIGUOUS
  NONE
}

enum DuplicateSignalKind {
  CANDIDATE_CANDIDATE
  CANDIDATE_CANONICAL
}

enum DuplicateSignalStatus {
  ACTIVE
  SUPERSEDED
}

enum ReviewQueueStatus {
  PENDING
  IN_REVIEW
  APPROVED_FOR_PUBLISH
  REJECTED
  PUBLISHED
  SUPERSEDED
  UNPUBLISHED
}

enum ReviewDecisionType {
  APPROVE
  REJECT
  MERGE
  REPLACE
  UNPUBLISH
}

enum PublishOperationType {
  CREATE_TITLE
  MERGE_INTO_EXISTING
  REPLACE_EXISTING
  UNPUBLISH_EXISTING
}

enum PublishOperationStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PublishAuditAction {
  QUEUED
  REVIEW_STARTED
  REVIEW_DECISION_RECORDED
  PUBLISH_STARTED
  PUBLISH_SUCCEEDED
  PUBLISH_FAILED
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  displayName      String
  avatarUrl        String?
  role             UserRole          @default(USER)
  plan             UserPlan          @default(FREE)
  locale           String            @default("zh-CN")
  timezone         String            @default("Asia/Shanghai")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  preferences      UserPreference?
  searches         SearchQuery[]
  browseEvents     BrowseEvent[]
  watchProgress    WatchProgress[]
  playbackSessions PlaybackSession[]
  lists            UserList[]
  resourceEvents   ResourceEvent[]
}

model UserPreference {
  id                   String             @id @default(cuid())
  userId               String             @unique
  autoplay             Boolean            @default(true)
  preferHighQuality    Boolean            @default(true)
  preferDubbed         Boolean            @default(false)
  matureContentEnabled Boolean            @default(true)
  favoriteGenres       String[]           @default([])
  blockedTags          String[]           @default([])
  preferredProviders   ResourceProvider[] @default([])
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MediaTitle {
  id                    String            @id @default(cuid())
  publicId              String            @unique
  slug                  String            @unique
  title                 String
  originalTitle         String?
  summary               String
  description           String?
  tagline               String?
  type                  MediaType
  status                MediaStatus       @default(DRAFT)
  releaseYear           Int
  endYear               Int?
  originCountry         String?
  language              String?
  runtimeMinutes        Int?
  episodeRuntimeMinutes Int?
  seasonCount           Int?
  episodeCount          Int?
  ratingValue           Decimal?          @db.Decimal(3, 1)
  ratingCount           Int               @default(0)
  popularityScore       Float             @default(0)
  isFeatured            Boolean           @default(false)
  publishedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  alternateTitles       MediaAlternateTitle[]
  genres                MediaGenre[]
  tags                  MediaTag[]
  countries             MediaCountry[]
  credits               MediaCredit[]
  artwork               Artwork[]
  seasons               Season[]
  episodes              Episode[]
  resources             Resource[]
  searches              SearchQuery[]
  browseEvents          BrowseEvent[]
  watchProgress         WatchProgress[]
  playbackSessions      PlaybackSession[]
  listItems             UserListItem[]
  ratingSnapshots       RatingSnapshot[]
  incomingMatchSuggestions MatchSuggestion[]
  incomingDuplicateSignals DuplicateSignal[]
  reviewQueueEntries    ReviewQueueEntry[]      @relation("ReviewQueueCanonicalMedia")
  reviewDecisions       ReviewDecision[]        @relation("ReviewDecisionCanonicalMedia")
  publishOperationTargets PublishOperation[]    @relation("PublishOperationTargetCanonicalMedia")
  publishOperationResults PublishOperation[]    @relation("PublishOperationResultCanonicalMedia")
  publishAuditRecords   PublishAuditRecord[]    @relation("PublishAuditCanonicalMedia")
}

model MediaAlternateTitle {
  id           String     @id @default(cuid())
  mediaId      String
  languageCode String     @default("zh-CN")
  value        String
  media        MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
}

model Genre {
  id    String      @id @default(cuid())
  slug  String      @unique
  label String
  media MediaGenre[]
}

model MediaGenre {
  mediaId String
  genreId String
  media   MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  genre   Genre      @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mediaId, genreId])
  @@index([genreId])
}

model Tag {
  id    String     @id @default(cuid())
  slug  String     @unique
  label String
  media MediaTag[]
}

model MediaTag {
  mediaId String
  tagId   String
  media   MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tag     Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mediaId, tagId])
  @@index([tagId])
}

model Country {
  code  String         @id
  label String
  media MediaCountry[]
}

model MediaCountry {
  mediaId      String
  countryCode  String
  media        MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  country      Country    @relation(fields: [countryCode], references: [code], onDelete: Cascade)

  @@id([mediaId, countryCode])
  @@index([countryCode])
}

model Person {
  id         String       @id @default(cuid())
  slug       String       @unique
  name       String
  nativeName String?
  avatarUrl  String?
  credits    MediaCredit[]
}

model MediaCredit {
  id            String     @id @default(cuid())
  mediaId       String
  personId      String
  role          CreditRole
  billingOrder  Int?
  characterName String?
  media         MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  person        Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([mediaId, personId, role, characterName])
  @@index([personId, role])
}

model Season {
  id           String     @id @default(cuid())
  mediaId      String
  seasonNumber Int
  title        String?
  releaseYear  Int?
  episodeCount Int?
  media        MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episodes     Episode[]

  @@unique([mediaId, seasonNumber])
}

model Episode {
  id             String             @id @default(cuid())
  publicId       String             @unique
  mediaId        String
  seasonId       String?
  episodeNumber  Int?
  slug           String
  title          String
  summary        String?
  runtimeMinutes Int?
  airDate        DateTime?
  media          MediaTitle         @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  season         Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  resources      Resource[]
  listItems      UserListItem[]
  watchProgress  WatchProgress[]
  playbackSessions PlaybackSession[]

  @@unique([mediaId, slug])
  @@index([seasonId, episodeNumber])
}

model Artwork {
  id        String      @id @default(cuid())
  mediaId   String
  kind      ArtworkKind
  url       String
  width     Int?
  height    Int?
  altText   String?
  isPrimary Boolean     @default(false)
  media     MediaTitle  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId, kind])
}

model Resource {
  id               String            @id @default(cuid())
  publicId         String            @unique
  mediaId          String
  episodeId        String?
  kind             ResourceKind
  provider         ResourceProvider
  format           ResourceFormat
  label            String
  quality          String?
  url              String
  maskedUrl        String?
  accessCode       String?
  status           ResourceStatus    @default(ONLINE)
  mirrorOrder      Int               @default(0)
  reportCount      Int               @default(0)
  lastCheckedAt    DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  media            MediaTitle        @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode          Episode?          @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  playbackSessions PlaybackSession[]
  resourceEvents   ResourceEvent[]

  @@index([mediaId, kind, status])
  @@index([episodeId, kind])
}

model UserList {
  id        String         @id @default(cuid())
  publicId  String?        @unique
  userId    String
  name      String
  description String?
  coverImageUrl String?
  type      ListType       @default(WATCHLIST)
  isSystem  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     UserListItem[]

  @@unique([userId, name])
}

model UserListItem {
  listId     String
  mediaId    String
  episodeId  String?
  publicRef  String?    @unique
  position   Int?
  addedAt    DateTime   @default(now())
  list       UserList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  media      MediaTitle @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode    Episode?   @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@id([listId, mediaId])
  @@index([listId, position])
  @@index([episodeId])
}

model SearchQuery {
  id              String      @id @default(cuid())
  userId          String?
  mediaId         String?
  query           String
  normalizedQuery String
  scope           SearchScope @default(ALL)
  resultCount     Int         @default(0)
  clickedRank     Int?
  sourcePage      String?
  createdAt       DateTime    @default(now())
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  media           MediaTitle? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  browseEvents    BrowseEvent[]

  @@index([userId, createdAt])
  @@index([normalizedQuery])
}

model BrowseEvent {
  id            String          @id @default(cuid())
  userId        String?
  mediaId       String?
  searchQueryId String?
  eventType     BrowseEventType
  sessionId     String?
  route         String
  referrer      String?
  deviceType    DeviceType      @default(WEB)
  position      Int?
  durationMs    Int?
  createdAt     DateTime        @default(now())
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  media         MediaTitle?     @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  searchQuery   SearchQuery?    @relation(fields: [searchQueryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([mediaId, eventType, createdAt])
}

model WatchProgress {
  id               String      @id @default(cuid())
  userId           String
  mediaId          String
  episodeId        String?
  progressSeconds  Int         @default(0)
  durationSeconds  Int?
  progressPercent  Float       @default(0)
  lastPositionAt   DateTime    @default(now())
  completedAt      DateTime?
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  media            MediaTitle  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode          Episode?    @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([userId, mediaId, lastPositionAt])
  @@index([episodeId])
}

model PlaybackSession {
  id                 String       @id @default(cuid())
  userId             String?
  mediaId            String
  episodeId          String?
  resourceId         String?
  deviceType         DeviceType   @default(WEB)
  ipCountry          String?
  startedAt          DateTime     @default(now())
  endedAt            DateTime?
  maxProgressSeconds Int          @default(0)
  completed          Boolean      @default(false)
  user               User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  media              MediaTitle   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode            Episode?     @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  resource           Resource?    @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([mediaId, startedAt])
}

model ResourceEvent {
  id           String         @id @default(cuid())
  userId       String?
  resourceId   String
  action       ResourceAction
  contextRoute String?
  createdAt    DateTime       @default(now())
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  resource     Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, action, createdAt])
}

model RatingSnapshot {
  id          String      @id @default(cuid())
  mediaId     String
  source      String
  rating      Decimal     @db.Decimal(3, 1)
  ratingCount Int?
  capturedAt  DateTime    @default(now())
  media       MediaTitle  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId, capturedAt])
}

model ProviderRegistry {
  id                   String                 @id @default(cuid())
  adapterKey           String                 @unique
  displayName          String
  providerType         ProviderType
  capabilities         ProviderCapability[]   @default([])
  baseUrl              String?
  enabled              Boolean                @default(true)
  metadata             Json?
  lastSuccessfulSyncAt DateTime?
  lastErrorAt          DateTime?
  lastErrorSummary     String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  ingestJobs           IngestJob[]
  ingestRuns           IngestRun[]
  checkpoints          IngestCheckpoint[]
  rawPayloads          ProviderRawPayload[]
  providerItems        ProviderItem[]
  stagingCandidates    StagingCandidate[]
  normalizedCandidates NormalizedCandidate[]
}

model IngestJob {
  id               String            @id @default(cuid())
  providerId       String
  mode             IngestMode
  status           IngestJobStatus   @default(PENDING)
  requestId        String?
  actorId          String?
  startedAt        DateTime?
  finishedAt       DateTime?
  attemptCount     Int               @default(0)
  lastErrorSummary String?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  provider         ProviderRegistry  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  runs             IngestRun[]
  checkpoints      IngestCheckpoint[]
  rawPayloads      ProviderRawPayload[]
  stagingCandidates StagingCandidate[]

  @@index([providerId, status, mode])
  @@index([requestId])
}

model IngestRun {
  id               String            @id @default(cuid())
  ingestJobId      String
  providerId       String
  mode             IngestMode
  scope            IngestRunScope
  status           IngestRunStatus   @default(PENDING)
  requestId        String?
  actorId          String?
  providerItemId   String?
  startedAt        DateTime          @default(now())
  finishedAt       DateTime?
  itemCount        Int               @default(0)
  rawPayloadCount  Int               @default(0)
  warningCount     Int               @default(0)
  lastErrorSummary String?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ingestJob        IngestJob         @relation(fields: [ingestJobId], references: [id], onDelete: Cascade)
  provider         ProviderRegistry  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  checkpoints      IngestCheckpoint[]
  rawPayloads      ProviderRawPayload[]
  stagingCandidates StagingCandidate[]

  @@index([ingestJobId, status, startedAt])
  @@index([providerId, scope, startedAt])
}

model IngestCheckpoint {
  id                String            @id @default(cuid())
  providerId        String
  ingestJobId       String?
  ingestRunId       String?
  cursor            String?
  page              Int?
  updatedAfter      DateTime?
  updatedBefore     DateTime?
  providerUpdatedAt DateTime?
  metadata          Json?
  recordedAt        DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  provider          ProviderRegistry  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  ingestJob         IngestJob?        @relation(fields: [ingestJobId], references: [id], onDelete: Cascade)
  ingestRun         IngestRun?        @relation(fields: [ingestRunId], references: [id], onDelete: Cascade)

  @@index([providerId, recordedAt])
  @@index([ingestJobId])
  @@index([ingestRunId])
}

model ProviderItem {
  id                     String                 @id @default(cuid())
  providerId             String
  externalId             String
  titleSnapshot          String
  originalTitleSnapshot  String?
  latestStatus           ProviderItemStatus    @default(DISCOVERED)
  typeHint               ProviderContentTypeHint @default(UNKNOWN)
  providerUpdatedAt      DateTime?
  lastSeenAt             DateTime              @default(now())
  latestRawPayloadAt     DateTime?
  latestCandidateStatus  StagingCandidateStatus?
  latestCandidateAt      DateTime?
  metadata               Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  provider               ProviderRegistry      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  rawPayloads            ProviderRawPayload[]
  stagingCandidates      StagingCandidate[]
  normalizedCandidates   NormalizedCandidate[]

  @@unique([providerId, externalId])
  @@index([providerId, latestStatus, lastSeenAt])
}

model ProviderRawPayload {
  id             String                @id @default(cuid())
  providerId     String
  ingestJobId    String?
  ingestRunId    String?
  providerItemId String?
  externalItemId String?
  payloadFormat  ProviderPayloadFormat
  scope          IngestRunScope
  requestUrl     String?
  requestMethod  String?
  requestCursor  String?
  requestPage    Int?
  body           Json
  fetchedAt      DateTime
  createdAt      DateTime              @default(now())
  provider       ProviderRegistry      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  ingestJob      IngestJob?            @relation(fields: [ingestJobId], references: [id], onDelete: Cascade)
  ingestRun      IngestRun?            @relation(fields: [ingestRunId], references: [id], onDelete: Cascade)
  providerItem   ProviderItem?         @relation(fields: [providerItemId], references: [id], onDelete: SetNull)

  @@index([providerId, fetchedAt])
  @@index([ingestJobId])
  @@index([ingestRunId])
  @@index([providerItemId])
}

model StagingCandidate {
  id                    String                  @id @default(cuid())
  providerId            String
  providerItemId        String
  ingestJobId           String?
  ingestRunId           String?
  status                StagingCandidateStatus @default(READY_FOR_NORMALIZATION)
  title                 String
  originalTitle         String?
  summary               String?
  releaseYear           Int?
  region                String?
  language              String?
  rawCategory           String?
  rawEpisodeText        String?
  typeHint              ProviderContentTypeHint @default(UNKNOWN)
  providerUpdatedAt     DateTime?
  sourceFragmentSummary Json?
  warnings              String[]               @default([])
  parseFailureSummary   String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  provider              ProviderRegistry       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerItem          ProviderItem           @relation(fields: [providerItemId], references: [id], onDelete: Cascade)
  ingestJob             IngestJob?             @relation(fields: [ingestJobId], references: [id], onDelete: SetNull)
  ingestRun             IngestRun?             @relation(fields: [ingestRunId], references: [id], onDelete: SetNull)
  normalizedCandidate   NormalizedCandidate?

  @@index([providerId, status, updatedAt])
  @@index([providerItemId, status])
  @@index([ingestJobId])
  @@index([ingestRunId])
}

model NormalizedCandidate {
  id                     String                    @id @default(cuid())
  stagingCandidateId     String                    @unique
  providerId             String
  providerItemId         String
  status                 NormalizedCandidateStatus @default(NORMALIZED)
  titleDisplay           String
  titleComparable        String
  originalTitleDisplay   String?
  originalTitleComparable String?
  summary                String?
  mediaType              NormalizedMediaType       @default(UNKNOWN)
  releaseYear            Int?
  region                 String?
  language               String?
  seasonEpisodeHints     Json?
  sourceSummary          Json?
  evidence               Json?
  warnings               String[]                  @default([])
  normalizationNotes     String[]                  @default([])
  failureSummary         String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  provider               ProviderRegistry          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerItem           ProviderItem              @relation(fields: [providerItemId], references: [id], onDelete: Cascade)
  stagingCandidate       StagingCandidate          @relation(fields: [stagingCandidateId], references: [id], onDelete: Cascade)
  aliases                CandidateAlias[]
  matchSuggestions       MatchSuggestion[]         @relation("SourceCandidateMatchSuggestions")
  incomingMatchSuggestions MatchSuggestion[]       @relation("TargetCandidateMatchSuggestions")
  duplicateSignals       DuplicateSignal[]         @relation("SourceCandidateDuplicateSignals")
  incomingDuplicateSignals DuplicateSignal[]       @relation("TargetCandidateDuplicateSignals")
  reviewQueueEntry       ReviewQueueEntry?
  reviewDecisions        ReviewDecision[]
  publishOperations      PublishOperation[]
  publishAuditRecords    PublishAuditRecord[]

  @@index([providerId, status, updatedAt])
  @@index([providerItemId, updatedAt])
  @@index([mediaType, releaseYear])
}

model CandidateAlias {
  id                    String               @id @default(cuid())
  normalizedCandidateId String
  source                CandidateAliasSource
  displayValue          String
  comparableValue       String
  note                  String?
  createdAt             DateTime             @default(now())
  normalizedCandidate   NormalizedCandidate  @relation(fields: [normalizedCandidateId], references: [id], onDelete: Cascade)

  @@unique([normalizedCandidateId, source, comparableValue])
  @@index([comparableValue])
}

model MatchSuggestion {
  id                        String               @id @default(cuid())
  normalizedCandidateId     String
  targetSource              MatchTargetSource
  targetCanonicalMediaId    String?
  targetNormalizedCandidateId String?
  kind                      MatchSuggestionKind
  confidence                Float
  reasons                   Json
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  normalizedCandidate       NormalizedCandidate  @relation("SourceCandidateMatchSuggestions", fields: [normalizedCandidateId], references: [id], onDelete: Cascade)
  targetCanonicalMedia      MediaTitle?          @relation(fields: [targetCanonicalMediaId], references: [id], onDelete: SetNull)
  targetNormalizedCandidate NormalizedCandidate? @relation("TargetCandidateMatchSuggestions", fields: [targetNormalizedCandidateId], references: [id], onDelete: SetNull)

  @@index([normalizedCandidateId, kind, confidence])
  @@index([targetCanonicalMediaId])
  @@index([targetNormalizedCandidateId])
}

model DuplicateSignal {
  id                        String                @id @default(cuid())
  sourceNormalizedCandidateId String
  targetSource              MatchTargetSource
  targetCanonicalMediaId    String?
  targetNormalizedCandidateId String?
  kind                      DuplicateSignalKind
  status                    DuplicateSignalStatus @default(ACTIVE)
  confidence                Float
  reasons                   Json
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  sourceNormalizedCandidate NormalizedCandidate   @relation("SourceCandidateDuplicateSignals", fields: [sourceNormalizedCandidateId], references: [id], onDelete: Cascade)
  targetCanonicalMedia      MediaTitle?           @relation(fields: [targetCanonicalMediaId], references: [id], onDelete: SetNull)
  targetNormalizedCandidate NormalizedCandidate?  @relation("TargetCandidateDuplicateSignals", fields: [targetNormalizedCandidateId], references: [id], onDelete: SetNull)

  @@index([sourceNormalizedCandidateId, kind, status, confidence])
  @@index([targetCanonicalMediaId])
  @@index([targetNormalizedCandidateId])
}

model ReviewQueueEntry {
  id                    String             @id @default(cuid())
  normalizedCandidateId String             @unique
  canonicalMediaId      String?
  status                ReviewQueueStatus  @default(PENDING)
  assignedReviewerId    String?
  latestDecisionType    ReviewDecisionType?
  latestDecisionSummary String?
  queuedAt              DateTime           @default(now())
  startedAt             DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  normalizedCandidate   NormalizedCandidate @relation(fields: [normalizedCandidateId], references: [id], onDelete: Cascade)
  canonicalMedia        MediaTitle?        @relation("ReviewQueueCanonicalMedia", fields: [canonicalMediaId], references: [id], onDelete: SetNull)
  decisions             ReviewDecision[]
  publishOperations     PublishOperation[]
  audits                PublishAuditRecord[]

  @@index([status, queuedAt])
  @@index([canonicalMediaId])
}

model ReviewDecision {
  id                    String             @id @default(cuid())
  queueEntryId          String
  normalizedCandidateId String
  decisionType          ReviewDecisionType
  actorId               String?
  targetCanonicalMediaId String?
  notes                 String?
  createdAt             DateTime           @default(now())
  queueEntry            ReviewQueueEntry   @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  normalizedCandidate   NormalizedCandidate @relation(fields: [normalizedCandidateId], references: [id], onDelete: Cascade)
  targetCanonicalMedia  MediaTitle?        @relation("ReviewDecisionCanonicalMedia", fields: [targetCanonicalMediaId], references: [id], onDelete: SetNull)
  publishOperations     PublishOperation[]
  audits                PublishAuditRecord[]

  @@index([queueEntryId, createdAt])
  @@index([normalizedCandidateId, decisionType, createdAt])
  @@index([targetCanonicalMediaId])
}

model PublishOperation {
  id                      String                @id @default(cuid())
  queueEntryId            String
  reviewDecisionId        String
  normalizedCandidateId   String
  actorId                 String?
  operationType           PublishOperationType
  status                  PublishOperationStatus @default(PENDING)
  targetCanonicalMediaId  String?
  resultingCanonicalMediaId String?
  operationSummary        String?
  failureSummary          String?
  startedAt               DateTime             @default(now())
  completedAt             DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  queueEntry              ReviewQueueEntry     @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  reviewDecision          ReviewDecision       @relation(fields: [reviewDecisionId], references: [id], onDelete: Cascade)
  normalizedCandidate     NormalizedCandidate  @relation(fields: [normalizedCandidateId], references: [id], onDelete: Cascade)
  targetCanonicalMedia    MediaTitle?          @relation("PublishOperationTargetCanonicalMedia", fields: [targetCanonicalMediaId], references: [id], onDelete: SetNull)
  resultingCanonicalMedia MediaTitle?          @relation("PublishOperationResultCanonicalMedia", fields: [resultingCanonicalMediaId], references: [id], onDelete: SetNull)
  audits                  PublishAuditRecord[]

  @@index([queueEntryId, createdAt])
  @@index([reviewDecisionId])
  @@index([status, startedAt])
  @@index([targetCanonicalMediaId])
  @@index([resultingCanonicalMediaId])
}

model PublishAuditRecord {
  id                    String              @id @default(cuid())
  queueEntryId          String?
  reviewDecisionId      String?
  publishOperationId    String?
  normalizedCandidateId String?
  actorId               String?
  action                PublishAuditAction
  actionSummary         String
  targetCanonicalMediaId String?
  metadata              Json?
  createdAt             DateTime            @default(now())
  queueEntry            ReviewQueueEntry?   @relation(fields: [queueEntryId], references: [id], onDelete: SetNull)
  reviewDecision        ReviewDecision?     @relation(fields: [reviewDecisionId], references: [id], onDelete: SetNull)
  publishOperation      PublishOperation?   @relation(fields: [publishOperationId], references: [id], onDelete: SetNull)
  normalizedCandidate   NormalizedCandidate? @relation(fields: [normalizedCandidateId], references: [id], onDelete: SetNull)
  targetCanonicalMedia  MediaTitle?         @relation("PublishAuditCanonicalMedia", fields: [targetCanonicalMediaId], references: [id], onDelete: SetNull)

  @@index([queueEntryId, createdAt])
  @@index([reviewDecisionId, createdAt])
  @@index([publishOperationId, createdAt])
  @@index([normalizedCandidateId, createdAt])
  @@index([targetCanonicalMediaId, createdAt])
}
